#!/bin/bash

# ============================================
# Author:       Adam Brandeis
# Filename:     .function_topfiles
# Created:      2026-01-20
# Purpose:      List the top N largest files recursively from the current directory
#               with a header timestamp and per-file modification date/time.
# ============================================


########################
## [Function topfiles] #
# List the top N largest files recursively from the current directory,
# with a header timestamp and per-file modification date/time.
# Usage:
#   topfiles         # default top 10
#   topfiles 5       # top 5
#   topfiles 15      # top 15

topfiles() {
  local n="${1:-10}"
  local color_mode="auto"  # auto|always|never
  local arg

  # Parse optional --color/--no-color (keep it simple; first non-flag is N)
  while [[ "$1" == --* ]]; do
    arg="$1"; shift
    case "$arg" in
      --no-color)     color_mode="never" ;;
      --color=always) color_mode="always" ;;
      --color=auto)   color_mode="auto" ;;
      --color=never)  color_mode="never" ;;
      *) echo "Unknown option: $arg" >&2; return 2 ;;
    esac
  done

  # If next positional exists, it's N
  if [[ -n "${1:-}" ]]; then
    n="$1"
  fi

  # Validate N
  if ! [[ "$n" =~ ^[0-9]+$ ]] || [[ "$n" -le 0 ]]; then
    echo "Usage: topfiles [N] [--color=auto|always|never|--no-color]" >&2
    return 2
  fi

  # Decide whether to colorize
  local use_color=0
  if [[ "$color_mode" == "always" ]]; then
    use_color=1
  elif [[ "$color_mode" == "never" ]]; then
    use_color=0
  else
    # auto: only when stdout is a TTY and NO_COLOR not set
    if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
      use_color=1
    fi
  fi

  # Resolve color sequences (yellow for size/date)
  # Prefer tput (terminal capabilities); fallback to ANSI escapes.
  local YELLOW="" RESET=""
  if [[ "$use_color" -eq 1 ]]; then
    if command -v tput >/dev/null 2>&1; then
      # 3 = yellow (may vary by theme); sgr0 resets.
      YELLOW="$(tput setaf 3 2>/dev/null || true)"
      RESET="$(tput sgr0 2>/dev/null || true)"
    fi
    # Fallbacks if tput failed or returned empty
    [[ -z "$YELLOW" ]] && YELLOW=$'\033[33m'
    [[ -z "$RESET"  ]] && RESET=$'\033[0m'
  fi

  # Header with current timestamp (local)
  local now
  now="$(date '+%Y-%m-%d %H:%M:%S %Z')"
  echo "Top ${n} largest files under: $(pwd)"
  echo "As of: ${now}"
  echo "------------------------------------------------------------"

  # Prefer GNU find's -printf (size, mtime, path) with NUL separation.
  if find . -type f -printf '%s\t%TY-%Tm-%Td %TH:%TM\t%p\0' >/dev/null 2>&1; then
    find . -type f -printf '%s\t%TY-%Tm-%Td %TH:%TM\t%p\0' 2>/dev/null \
      | sort -z -t $'\t' -k1,1nr \
      | awk -v RS='\0' -F"\t" -v n="$n" -v sc="$YELLOW" -v dc="$YELLOW" -v rc="$RESET" '
          function human(bytes,  u, v) {
            v=bytes+0; u="B";
            if (v>=1024){v/=1024;u="K"}
            if (v>=1024){v/=1024;u="M"}
            if (v>=1024){v/=1024;u="G"}
            if (v>=1024){v/=1024;u="T"}
            return (v>=10) ? sprintf("%4.0f%s", v, u) : sprintf("%4.1f%s", v, u)
          }
          NF>=3 {
            if (count++ < n) {
              sz = human($1);
              dt = $2;
              # If color strings are non-empty, wrap size/date
              if (length(sc)) sz = sc sz rc;
              if (length(dc)) dt = dc dt rc;
              printf "%8s  %-16s  %s\n", sz, dt, $3
            } else exit
          }'

  else
    # Fallbacks (newline-delimited; head -n works fine here)
    if stat -f '%z %N' / >/dev/null 2>&1; then
      # BSD/macOS stat
      find . -type f -print0 2>/dev/null \
        | xargs -0 -I{} stat -f '%z\t%Sm\t%N' -t '%Y-%m-%d %H:%M' "{}" 2>/dev/null \
        | LC_ALL=C sort -t $'\t' -k1,1nr \
        | head -n "$n" \
        | awk -F"\t" -v sc="$YELLOW" -v dc="$YELLOW" -v rc="$RESET" '
            function human(bytes,  u, v) {
              v=bytes+0; u="B";
              if (v>=1024){v/=1024;u="K"}
              if (v>=1024){v/=1024;u="M"}
              if (v>=1024){v/=1024;u="G"}
              if (v>=1024){v/=1024;u="T"}
              return (v>=10) ? sprintf("%4.0f%s", v, u) : sprintf("%4.1f%s", v, u)
            }
            NF>=3 {
              sz = human($1); dt = $2
              if (length(sc)) sz = sc sz rc;
              if (length(dc)) dt = dc dt rc;
              printf "%8s  %-16s  %s\n", sz, dt, $3
            }'
    elif stat -c '%s %n' / >/dev/null 2>&1; then
      # GNU stat
      find . -type f -print0 2>/dev/null \
        | xargs -0 -I{} stat -c '%s\t%y\t%n' "{}" 2>/dev/null \
        | LC_ALL=C sort -t $'\t' -k1,1nr \
        | head -n "$n" \
        | awk -F"\t" -v sc="$YELLOW" -v dc="$YELLOW" -v rc="$RESET" '
            function human(bytes,  u, v) {
              v=bytes+0; u="B";
              if (v>=1024){v/=1024;u="K"}
              if (v>=1024){v/=1024;u="M"}
              if (v>=1024){v/=1024;u="G"}
              if (v>=1024){v/=1024;u="T"}
              return (v>=10) ? sprintf("%4.0f%s", v, u) : sprintf("%4.1f%s", v, u)
            }
            {
              # mtime example: "2026-01-16 11:22:30.123456789 -0500"
              m=$2 " " $3
              sub(/\.[0-9]+$/, "", m)     # drop fractional seconds
              gsub(/:[0-9][0-9]$/, "", m) # keep YYYY-MM-DD HH:MM
              sz = human($1); dt = m
              if (length(sc)) sz = sc sz rc;
              if (length(dc)) dt = dc dt rc;
              printf "%8s  %-16s  %s\n", sz, dt, $4
            }'
    else
      echo "topfiles: neither GNU find -printf nor usable stat found." >&2
      return 1
    fi
  fi
}      ##### FUNCTION END : topfiles
